rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public access for Quick Login
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Temporarily public read access for debugging Windows Sync
    match /cases/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /attendance/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /shifts/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /inventory/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /procedures/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /activity_logs/{docId} { allow read: if true; allow write: if request.auth != null; }

    // Backup catch-all
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
